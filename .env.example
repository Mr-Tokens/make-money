# Copy this file to .env and fill in local credentials.
# Never commit .env. Rotate any token that was pasted into chat or logs.

# MiniMax OpenAI-compatible endpoint
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7

# Xiaomi Mimo OpenAI-compatible endpoint
# Token Plan may require a cluster-specific base URL from the Mimo subscription page.
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-pro

# OpenAI Agents SDK
# Keep real keys only in .env. For OpenAI-compatible non-OpenAI endpoints, many providers need chat_completions.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=
OPENAI_MANAGER_MODEL=
OPENAI_AGENTS_DEFAULT_API=
OPENAI_AGENTS_ENABLE_TRACING=0
